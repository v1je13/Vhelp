{
  "name": "traveldiary",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "npm run build && wrangler dev",
    "tunnel": "vk-tunnel --http-protocol=http --host=localhost --port=5173",
    "deploy": "npm run build && wrangler deploy",
    "deploy-gh": "gh-pages -d build",
    "server": "cd server && npm install && node server.js",
    "dev:server": "cd server && npm install && nodemon server.js"
  },
  "dependencies": {
    "@vitejs/plugin-legacy": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vkontakte/vk-bridge": "^2.15.11",
    "@vkontakte/vk-bridge-react": "^1.0.1",
    "@vkontakte/vk-mini-apps-router": "^1.7.6",
    "@vkontakte/vkui": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "esbuild": "~0.20.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "terser": "^5.4.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.32.3",
    "@vkontakte/vk-miniapps-deploy": "^0.1.6",
    "@vkontakte/vk-tunnel": "^0.2.4",
    "eruda": "^3.0.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "gh-pages": "^6.3.0",
    "wrangler": "^4.83.0"
  }
}
